{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "packages": {
    ".": {
      "release-type": "node",
      "package-name": "ai-learning-frontend",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": "src-tauri/tauri.conf.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "src-tauri": {
      "release-type": "rust",
      "package-name": "ai-learning-platform",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
