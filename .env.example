# AI 学堂 环境变量配置
# 复制此文件为 .env 并根据需要修改

# LLM API Key
# 支持 Anthropic (Claude) 或 DeepSeek
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# Provider 选择: anthropic / deepseek
API_PROVIDER=anthropic

# 模型选择
# Anthropic: claude-sonnet-4-20250514 / claude-haiku-4-5-20251001 / claude-opus-4-7
# DeepSeek: deepseek-chat / deepseek-reasoner
MODEL=claude-sonnet-4-20250514

# 主题: dark / light
THEME=dark
